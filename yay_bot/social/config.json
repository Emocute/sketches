{
  "_comment": "Yay フォロワー成長 bot の設定。dry_run=true の間は一切の書き込み(フォロー/投稿/いいね)を実行せず、何をするかをログに出すだけ。実運用は究GO後に false へ。攻め度=中。",

  "dry_run": false,
  "self_uid": 11320230,

  "claude_model": "claude-opus-4-8",
  "reply_timeout_ms": 60000,

  "poll": {
    "activity_sec": 90,
    "engage_min": 25
  },

  "followback": {
    "enabled": true,
    "max_per_hour": 20,
    "quality": {
      "min_posts": 1,
      "circle_keywords": ["相互", "フォロバ", "リフォロー", "フォロー返", "無言フォロー", "f4f", "follow4follow", "followback", "follow back", "全フォロ", "フォロ爆"]
    }
  },

  "post": {
    "enabled": true,
    "per_day": 4,
    "min_gap_min": 180,
    "active_hours": [9, 24],
    "avoid_recent": 8,
    "intents": [
      "フォロワーが思わず答えたくなる、軽い問いを1つ投げる（日常・好み・選択など答えやすいもの）",
      "知ってると少し得する豆知識・コツを1つ、具体的に短く",
      "ありふれた物事の意外な見方・小さな発見を1つ",
      "今日の素朴な疑問を1つ。答えやすく、議論を呼びすぎないもの",
      "『何か気になってること、投げてくれたら答えるよ』を自然に織り込んだ軽い投稿（あからさまな宣伝にしない）"
    ]
  },

  "mention_reply": {
    "enabled": true,
    "max_per_hour": 15,
    "reply_types": ["reply", "post_reply", "mention", "comment", "comment_reply", "thread_reply", "reply_to_comment"]
  },

  "proactive": {
    "enabled": true,
    "max_replies_per_hour": 6,
    "max_likes_per_hour": 40,
    "source": "tag",
    "tags": ["雑談", "暇", "質問", "相談", "ひとりごと", "AI"],
    "experiment_num": 1,
    "variant_num": 1,
    "reply_ratio": 0.0,
    "_reply_ratio_note": "初動はコールドリプ停止(BAN回避)。bio設定＋メンション返信が回り土台ができたら 0.35 に戻す",
    "max_targets_per_cycle": 8
  },

  "throttle": {
    "min_action_gap_sec": 12,
    "jitter_sec": 10
  },

  "quiet_hours": [2, 7],

  "skip_users": []
}
