# LINE Messaging API（LINE Developers コンソールから取得）
LINE_CHANNEL_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LINE_CHANNEL_ACCESS_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 任意
PORT=8787
CLAUDE_MODEL=sonnet
BOT_NAME=クロ
# 反応条件: mention_or_prefix（既定）| always（全発言に反応＝Max枠を食う）
TRIGGER_MODE=mention_or_prefix
# 接頭辞トリガー（カンマ区切り、大小無視で部分一致）
TRIGGER_PREFIXES=クロ,くろ,bot,Bot
# 何往復ぶん文脈を保持するか
MAX_HISTORY=24
# 任意: メンション判定用にボット自身の userId（起動時に /v2/bot/info から自動取得もする）
# LINE_BOT_USER_ID=
